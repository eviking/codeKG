# ── Required ──────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=codekg_dev
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=          # optional — enables GPT and o-series models
REPOS_PATH=./repos

# Mount your home directory so containers can reach repos anywhere on your machine.
# Set to your home dir (or any parent of your repos); use /host-home/... in the UI.
HOME_MOUNT=

# ── LLM models ────────────────────────────────────────────────────────────────
# Model for natural-language → Cypher translation (fast, cheap)
NL_QUERY_MODEL=claude-haiku-4-5
# Model for answering complex questions (more capable)
NL_ANSWER_MODEL=claude-sonnet-4-5
# Model for policy Cypher compilation
POLICY_MODEL=claude-haiku-4-5-20251001
# Local Ollama model for class summarisation
SUMMARY_MODEL=qwen2.5-coder:7b
# Ollama base URL — must be reachable from inside Docker
# macOS: http://host.docker.internal:11434  |  Linux: http://172.17.0.1:11434
OLLAMA_URL=http://host.docker.internal:11434

# ── LLM token limits ──────────────────────────────────────────────────────────
NL_CYPHER_MAX_TOKENS=600
NL_ANSWER_MAX_TOKENS=800
NL_ANSWER_MAX_TOKENS_FAST=500
POLICY_MAX_TOKENS=512
SUMMARISE_MAX_TOKENS=4096

# ── Ingestion ─────────────────────────────────────────────────────────────────
POLL_INTERVAL=30
WORKER_COUNT=0          # 0 = use all CPUs
PARSE_BATCH_SIZE=200
WIRE_EDGES_TIMEOUT=90   # seconds — do not lower without Neo4j load testing
# Optional: explicit path to summarise_classes.py if auto-discovery fails
# Auto-discovery searches /app/tools/ (container) then any path in the repo registry
SUMMARISE_TOOL_PATH=

# ── Agent index ───────────────────────────────────────────────────────────────
# Repos below this LOC threshold get a single combined module file
AGENT_INDEX_COMBINED_LOC_THRESHOLD=2500
# Module count above which the modules overview switches to compact index mode
AGENT_INDEX_LARGE_REPO_THRESHOLD=100

# ── Neo4j memory ─────────────────────────────────────────────────────────────
# Tune these for your host machine. Total: heap_max + pagecache ≤ available RAM
NEO4J_HEAP_INITIAL=2g
NEO4J_HEAP_MAX=4g
NEO4J_PAGECACHE=2g

# ── API authentication ────────────────────────────────────────────────────────
# Set to a long random string to require bearer-token auth on all API requests.
# Leave empty for open/single-user mode (appropriate for localhost).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be the same value in API, console, and MCP services.
API_TOKEN=

# ── GitHub OAuth (console) ────────────────────────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:8080/auth/callback  (or your production URL)
# Leave GITHUB_CLIENT_ID empty to disable auth (single-user localhost mode).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random secret used to sign session cookies. Must be set when GitHub auth is enabled.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Session cookie lifetime in seconds (default 30 days)
SESSION_MAX_AGE=2592000

# ── Access control (pick one, or leave all empty to allow any GitHub user) ────
# Option A: org + team membership (most granular)
GITHUB_ORG=
GITHUB_TEAM=            # team slug, e.g. "platform-engineers"
# Option B: org membership only — set GITHUB_ORG, leave GITHUB_TEAM empty
# Option C: explicit allowlist (comma-separated GitHub usernames, no org needed)
ALLOWED_GITHUB_USERS=

# ── MCP server ────────────────────────────────────────────────────────────────
# "stdio" for local Claude Code  |  "sse" for shared/network access
MCP_TRANSPORT=stdio
MCP_PORT=8002
